# ClearPath site — env vars
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Public site URL (used for canonicals, OG, sitemap). Production: https://clearpathwv.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tally.so lead-intake form ID — the segment after `tally.so/r/` in the form's
# share URL. Operator-confirmed 2026-05-02 (Me8OxM = "ClearPath Lead Intake").
# Without this set, the contact page renders the mailto-fallback to
# JWhalen@ClearPathWV.com instead of the embed.
NEXT_PUBLIC_TALLY_FORM_ID=Me8OxM

# Plausible Analytics domain — DEFERRED for Phase 1 (operator chose Vercel
# Analytics). Leave blank. Set only if Plausible replaces Vercel Analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Resend API key — DEFERRED for Phase 1 (Tally handles email natively).
# Wire only if the Resend fallback path replaces Tally in a future sprint.
RESEND_API_KEY=

# Where lead-form submissions get emailed. For Phase 1 this is configured
# inside Tally's notification settings, NOT as a Vercel env var. The
# canonical destination is JWhalen@ClearPathWV.com.
LEAD_EMAIL_TO=

# Private contacts backend — Phase 1
# Required before /admin/contacts or /api/admin/contacts will return data.
CLEARPATH_ADMIN_TOKEN=

# Local smoke testing can use memory. Production should use supabase.
CLEARPATH_CONTACTS_STORAGE=memory

# Durable contacts storage, used when CLEARPATH_CONTACTS_STORAGE=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CLEARPATH_CONTACTS_TABLE=clearpath_contacts

# Tally webhook import — use a long random value and keep it server-side.
# Webhook URL can include ?secret=... if custom headers are unavailable in Tally.
CLEARPATH_TALLY_WEBHOOK_SECRET=
