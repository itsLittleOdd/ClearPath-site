# ClearPath site — env vars
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Public site URL (used for OG tags, canonicals, sitemap). Production: https://clearpath.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Plausible Analytics domain (privacy-friendly analytics). Leave blank to disable. Example: clearpath.example.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Resend API key — only used by the React Hook Form fallback if Tally embed is disabled.
# Get one at https://resend.com — free tier covers 100 emails/day.
RESEND_API_KEY=

# Where lead-form submissions get emailed. Example: justin@clearpath.example.com
LEAD_EMAIL_TO=
